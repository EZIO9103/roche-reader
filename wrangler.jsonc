{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "roche-xhs-reader",
  "main": "src/index.js",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "browser": {
    "binding": "BROWSER"
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
}
